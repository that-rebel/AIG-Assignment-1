function evaluate_node(node::PlayerNode)
	if node.action == Pmin

		return minimum(map(cur_node -> evaluate_node(cur_node),node.nodes)
	else
		return max(map(cur_node -> evaluate_node(cur_node),node.nodes)
	end
end

function solve_game(game::Game)	
	return evaluate_node(game.initial)
end
